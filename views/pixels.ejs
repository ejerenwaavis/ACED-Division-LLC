<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aceddivision-v2.css">
  <link rel="icon" href="/img/aceddivision-Logo-Icon-Gold.png" type="image/png">
</head>
<body>

  <%- include('partials/navbar-v2') %>

  <section class="hero" id="heroSection">
    <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
    <div class="spotlight" id="spotlight"></div>
    <div class="grain"></div>
    <img class="watermark" src="/img/aceddivision-Logo-Icon-OnDark.png" alt="">
    
    <div class="hero-content reveal">
      <p class="eyebrow">ACED PIXELS · CREATIVE & VISUAL</p>
      <h1>Visual Systems Built to<br>Make You <em>Impossible to Ignore</em>.</h1>
      <p class="sub">Brand identity, photography, cinematography, graphic design, and conversion-focused visual systems — crafted to give your audience something they can't scroll past.</p>
      <div class="hero-cta">
        <a href="#services" class="btn btn-primary">Explore Services</a>
        <a href="#portfolio" class="btn btn-ghost">See Creative Work</a>
      </div>
    </div>
    
    <div class="scroll-cue">
      SCROLL<div class="line"></div>
    </div>
  </section>

  <div class="marquee reveal">
    <div class="marquee-track">
      <span>BRAND IDENTITY</span><span>PHOTOGRAPHY</span>
      <span>CINEMATOGRAPHY</span><span>GRAPHIC DESIGN</span>
      <span>WEB DESIGN</span><span>MOTION GRAPHICS</span>
      <span>VFX & ANIMATION</span>
      <span>BRAND IDENTITY</span><span>PHOTOGRAPHY</span>
      <span>CINEMATOGRAPHY</span><span>GRAPHIC DESIGN</span>
      <span>WEB DESIGN</span><span>MOTION GRAPHICS</span>
      <span>VFX & ANIMATION</span>
    </div>
  </div>

  <%- include('partials/stat-panel') %>

  <section class="work" id="services">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Capabilities</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Capabilities built for brand impact.</h2>
    </div>
    
    <div class="work-grid">
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">PHOTO</span>
        <h3>Photography</h3>
        <p>Professional photography capturing your brand, team, and products with precision and artistic vision — ready for web, print, and social.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">VIDEO</span>
        <h3>Cinematography & Video</h3>
        <p>High-quality video production and post-production services that tell your brand story with cinematic excellence and technical precision.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">DESIGN</span>
        <h3>Graphic Design</h3>
        <p>Custom design solutions including marketing materials, digital assets, pitch decks, and visual content that commands attention.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">BRAND</span>
        <h3>Brand Identity</h3>
        <p>Complete branding — logo, colour systems, typography, and guidelines — creating a cohesive visual identity that carries across every medium.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">WEB</span>
        <h3>Web Design</h3>
        <p>Conversion-focused, visually elevated web experiences that balance beautiful design with clear user journeys and measurable outcomes.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">MOTION</span>
        <h3>Motion & VFX</h3>
        <p>Visual effects and animation adding dynamic energy and professional polish to any visual communication — from social cuts to full productions.</p>
      </div>
    </div>
  </section>

  <% if (featuredProjects && featuredProjects.length > 0) { %>
  <section class="work" id="portfolio">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Execution</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Creative Portfolio</h2>
      <p style="color:var(--ash); margin-top:10px;">Visual systems, web platforms, and brand experiences delivered across a range of industries and creative objectives.</p>
    </div>
    
    <div class="work-grid">
      <% featuredProjects.forEach((project, index) => { %>
        <div class="work-card reveal" style="transition-delay:<%= (index+1)*0.1 %>s;">
          <% (project.tags || []).slice(0, 3).forEach((tag) => { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
          <h3><a href="/portfolio/<%= project.slug %>"><%= project.title %></a></h3>
          <p><%= project.description %></p>
        </div>
      <% }) %>
    </div>
    
    <div class="hero-cta reveal" style="margin-top:54px; justify-content:flex-start;">
      <a href="/portfolio?arm=pixels" class="btn btn-ghost">View All Creative Work</a>
    </div>
  </section>
  <% } %>

  <footer id="contact">
    <div class="aurora"><span class="a1"></span><span class="a2"></span></div>
    <div class="reveal">
      <p class="eyebrow" style="justify-content:center;margin-bottom:24px;">Engage</p>
      <h2>Your brand deserves visuals<br><em>that actually work.</em></h2>
      <p style="color:var(--ash); margin-top:20px; max-width:600px; margin-left:auto; margin-right:auto;">Tell us about your project — brand, campaign, web, or video — and we'll come back with a clear creative plan.</p>
      <div class="foot-cta">
        <a href="mailto:avis@aceddivision.com" class="btn btn-primary">Start a Project</a>
      </div>
    </div>
    
    <div class="foot-links">
      <div class="foot-brand">
        <img src="/img/aceddivision-Logo-Icon-OnDark.png" alt="ACED">
        <span>© 2026 ACED Division LLC</span>
      </div>
      <div class="foot-social">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/admin/login">Admin</a>
      </div>
    </div>
  </footer>

  <script src="/js/aceddivision-v2.js"></script>
</body>
</html>
