<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aceddivision-v2.css">
  <link rel="icon" href="/img/aceddivision-Logo-Icon-Gold.png" type="image/png">
</head>
<body>

  <%- include('partials/navbar-v2') %>

  <section class="hero" id="heroSection">
    <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
    <div class="spotlight" id="spotlight"></div>
    <div class="grain"></div>
    <img class="watermark" src="/img/aceddivision-Logo-Icon.png" alt="">
    
    <div class="hero-content reveal">
      <p class="eyebrow">ACED DEVOPS · SOFTWARE SYSTEMS</p>
      <h1>Engineering for<br><em>Scale & Precision</em>.</h1>
      <p class="sub">Production-grade software, APIs, routing intelligence, and business workflow systems built to handle complexity with measurable performance.</p>
      <div class="hero-cta">
        <a href="#services" class="btn btn-primary">Explore Services</a>
        <a href="#portfolio" class="btn btn-ghost">See Technical Work</a>
      </div>
    </div>
    
    <div class="scroll-cue">
      SCROLL<div class="line"></div>
    </div>
  </section>

  <div class="marquee reveal">
    <div class="marquee-track">
      <span>SOFTWARE ENGINEERING</span><span>SYSTEMS ARCHITECTURE</span>
      <span>AUTOMATION & APIS</span><span>ROUTING INTELLIGENCE</span>
      <span>SAAS PLATFORMS</span><span>CLOUD INFRASTRUCTURE</span>
      <span>BUSINESS WORKFLOWS</span>
      <span>SOFTWARE ENGINEERING</span><span>SYSTEMS ARCHITECTURE</span>
      <span>AUTOMATION & APIS</span><span>ROUTING INTELLIGENCE</span>
      <span>SAAS PLATFORMS</span><span>CLOUD INFRASTRUCTURE</span>
      <span>BUSINESS WORKFLOWS</span>
    </div>
  </div>

  <%- include('partials/stat-panel') %>

  <section class="work" id="services">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Capabilities</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Systems that drive operations.</h2>
    </div>
    
    <div class="work-grid">
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">SAAS</span>
        <h3>SaaS Platforms</h3>
        <p>Full-stack web applications and SaaS platforms built with modern technologies like Node.js, React, and MongoDB for scalable performance.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">API</span>
        <h3>API & Integrations</h3>
        <p>Custom API development and third-party integrations that connect your tools, automate workflows, and eliminate manual data entry.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">INFRA</span>
        <h3>Cloud Architecture</h3>
        <p>Reliable cloud infrastructure setup, deployment pipelines, and server management ensuring your applications stay online and performant.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">LOGISTICS</span>
        <h3>Routing Intelligence</h3>
        <p>Complex logistics and routing software designed to optimize routes, track assets, and manage daily node processing efficiently.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">AUTO</span>
        <h3>Business Automation</h3>
        <p>Internal tools and automated systems that replace tedious operational tasks with reliable, programmed workflows.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">DATA</span>
        <h3>Data Systems</h3>
        <p>Database architecture and management, ensuring data integrity, security, and fast querying for business intelligence applications.</p>
      </div>
    </div>
  </section>

  <% if (featuredProjects && featuredProjects.length > 0) { %>
  <section class="work" id="portfolio">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Execution</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Technical Portfolio</h2>
      <p style="color:var(--ash); margin-top:10px;">Software systems, logistics platforms, and automation tools engineered for operational efficiency.</p>
    </div>
    
    <div class="work-grid">
      <% featuredProjects.forEach((project, index) => { %>
        <div class="work-card reveal" style="transition-delay:<%= (index+1)*0.1 %>s;">
          <% (project.tags || []).slice(0, 3).forEach((tag) => { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
          <h3><a href="/portfolio/<%= project.slug %>"><%= project.title %></a></h3>
          <p><%= project.description %></p>
        </div>
      <% }) %>
    </div>
    
    <div class="hero-cta reveal" style="margin-top:54px; justify-content:flex-start;">
      <a href="/portfolio?arm=devops" class="btn btn-ghost">View All Technical Work</a>
    </div>
  </section>
  <% } %>

  <footer id="contact">
    <div class="aurora"><span class="a1"></span><span class="a2"></span></div>
    <div class="reveal">
      <p class="eyebrow" style="justify-content:center;margin-bottom:24px;">Engage</p>
      <h2>Let's build systems<br><em>with real impact.</em></h2>
      <p style="color:var(--ash); margin-top:20px; max-width:600px; margin-left:auto; margin-right:auto;">Tell us about your technical challenge — software, automation, or infrastructure — and we'll engineer the solution.</p>
      <div class="foot-cta">
        <a href="mailto:avis@aceddivision.com" class="btn btn-primary">Start a Project</a>
      </div>
    </div>
    
    <div class="foot-links">
      <div class="foot-brand">
        <img src="/img/aceddivision-Logo-Icon.png" alt="ACED">
        <span>© 2026 ACED Division LLC</span>
      </div>
      <div class="foot-social">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/admin/login">Admin</a>
      </div>
    </div>
  </footer>

  <script src="/js/aceddivision-v2.js"></script>
</body>
</html>
