<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aceddivision-v2.css">
  <link rel="icon" href="/img/aceddivision-Logo-Icon-Gold.png" type="image/png">
</head>
<body>

  <%- include('partials/navbar-v2') %>

  <section class="hero" id="heroSection">
    <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
    <div class="spotlight" id="spotlight"></div>
    <div class="grain"></div>
    <img class="watermark" src="/img/aceddivision-Logo-Icon.png" alt="">
    
    <div class="hero-content reveal">
      <p class="eyebrow">ACED DIVISION — THREE DISCIPLINES, ONE STANDARD</p>
      <h1>Systems, stories, <em>signals</em>.</h1>
      <p class="sub">We build high-impact digital products, media experiences, and trading intelligence systems that help ambitious teams move faster and scale with confidence.</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Start a Project</a>
        <a href="/portfolio" class="btn btn-ghost">See the Work</a>
      </div>
    </div>
    
    <div class="scroll-cue">
      SCROLL<div class="line"></div>
    </div>
  </section>

  <div class="marquee reveal">
    <div class="marquee-track">
      <span>ACED PIXELS</span><span>BRAND IDENTITY &amp; DESIGN</span>
      <span>ACED DEVOPS</span><span>SOFTWARE SYSTEMS</span>
      <span>ACED TRADES</span><span>FINANCIAL MARKETS</span>
      <span>ACED PIXELS</span><span>BRAND IDENTITY &amp; DESIGN</span>
      <span>ACED DEVOPS</span><span>SOFTWARE SYSTEMS</span>
      <span>ACED TRADES</span><span>FINANCIAL MARKETS</span>
    </div>
  </div>

  <section class="pillars" id="services">
    <div class="section-head reveal">
      <h2>Three specialized arms.<br>One cohesive standard.</h2>
      <p>Each division is focused, specialized, and execution-driven. Together, they form a complete growth engine for modern brands and operations.</p>
    </div>
    
    <div class="pillar-grid">
      <div class="pillar reveal" style="transition-delay:0.1s;">
        <span class="code">// DIVISION_01</span>
        <h3>Pixels</h3>
        <p>Brand identity, graphics, photography, cinematography, and conversion-focused visual systems that make your brand impossible to ignore.</p>
        <svg class="glyph"><circle cx="19" cy="19" r="14"/><path d="M19 5v28M5 19h28"/></svg>
        <a href="/pixels" class="go">See Pixels →</a>
      </div>
      
      <div class="pillar reveal" style="transition-delay:0.2s;">
        <span class="code">// DIVISION_02</span>
        <h3>Devops</h3>
        <p>Production-grade software, SaaS platforms, automation, APIs, routing intelligence, and business workflow systems built for measurable performance.</p>
        <svg class="glyph"><rect x="7" y="7" width="24" height="24" rx="3"/><path d="M7 15h24M15 22v9"/></svg>
        <a href="/devops" class="go">See Devops →</a>
      </div>
      
      <div class="pillar reveal" style="transition-delay:0.3s;">
        <span class="code">// DIVISION_03</span>
        <h3>Trades</h3>
        <p>Market strategy, risk-aware frameworks, and disciplined execution support across futures and forex environments.</p>
        <svg class="glyph"><path d="M5 29L15 15l8 6L33 5M33 5v9M33 5h-9"/></svg>
        <a href="/trades" class="go">See Trades →</a>
      </div>
    </div>
  </section>

  <%- include('partials/stat-panel') %>

  <section class="work" id="portfolio">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Execution</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Featured Portfolio</h2>
    </div>
    
    <div class="work-grid">
      <% if (featuredProjects && featuredProjects.length > 0) { %>
        <% featuredProjects.slice(0, 3).forEach((project, index) => { %>
          <div class="work-card reveal" style="transition-delay:<%= (index+1)*0.1 %>s;">
            <% (project.tags || []).slice(0, 3).forEach((tag) => { %>
              <span class="tag"><%= tag %></span>
            <% }) %>
            <h3><a href="/portfolio/<%= project.slug %>"><%= project.title %></a></h3>
            <p><%= project.description %></p>
          </div>
        <% }) %>
      <% } else { %>
        <div class="work-card reveal" style="transition-delay:0.1s;">
          <span class="tag">SOFTWARE</span>
          <h4>Fleet Command</h4>
          <p>Production logistics and routing intelligence dashboard processing over 3k daily nodes.</p>
        </div>
        <div class="work-card reveal" style="transition-delay:0.2s;">
          <span class="tag">MARKETS</span>
          <h4>Launch Model</h4>
          <p>Risk-adjusted framework targeting NQ and ES futures with automated journal sync.</p>
        </div>
        <div class="work-card reveal" style="transition-delay:0.3s;">
          <span class="tag">BRAND</span>
          <h4>Brand Systems</h4>
          <p>Complete visual overhauls for logistics and fintech groups standardizing identity across touchpoints.</p>
        </div>
      <% } %>
    </div>
    
    <div class="hero-cta reveal" style="margin-top:54px; justify-content:flex-start;">
      <a href="/portfolio" class="btn btn-ghost">View All Work</a>
    </div>
  </section>

  <footer id="contact">
    <div class="aurora"><span class="a1"></span><span class="a2"></span></div>
    <div class="reveal">
      <p class="eyebrow" style="justify-content:center;margin-bottom:24px;">Engage</p>
      <h2>Let’s build something<br><em>with real impact.</em></h2>
      <div class="foot-cta">
        <a href="mailto:avis@aceddivision.com" class="btn btn-primary">Start a Project</a>
      </div>
    </div>
    
    <div class="foot-links">
      <div class="foot-brand">
        <img src="/img/aceddivision-Logo-Icon.png" alt="ACED">
        <span>© 2026 ACED Division LLC</span>
      </div>
      <div class="foot-social">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/admin/login">Admin</a>
      </div>
    </div>
  </footer>

  <script src="/js/aceddivision-v2.js"></script>
</body>
</html>
