<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aceddivision-v2.css">
  <link rel="icon" href="/img/aceddivision-Logo-Icon-Gold.png" type="image/png">
</head>
<body>

  <%- include('partials/navbar-v2') %>

  <section class="hero" id="heroSection">
    <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
    <div class="spotlight" id="spotlight"></div>
    <div class="grain"></div>
    <img class="watermark" src="/img/aceddivision-Logo-Icon-OnDark.png" alt="">
    
    <div class="hero-content reveal">
      <p class="eyebrow">ACED TRADES · FINANCIAL MARKETS</p>
      <h1>Intelligence for<br><em>Disciplined Execution</em>.</h1>
      <p class="sub">Market strategy, risk-aware frameworks, and technical execution support across futures and forex environments.</p>
      <div class="hero-cta">
        <a href="#services" class="btn btn-primary">Explore Services</a>
        <a href="#portfolio" class="btn btn-ghost">See Market Work</a>
      </div>
    </div>
    
    <div class="scroll-cue">
      SCROLL<div class="line"></div>
    </div>
  </section>

  <div class="marquee reveal">
    <div class="marquee-track">
      <span>FUTURES TRADING</span><span>FOREX MARKETS</span>
      <span>RISK MANAGEMENT</span><span>TECHNICAL ANALYSIS</span>
      <span>ALGORITHMIC MODELS</span><span>JOURNALING SYSTEMS</span>
      <span>TRADE PSYCHOLOGY</span>
      <span>FUTURES TRADING</span><span>FOREX MARKETS</span>
      <span>RISK MANAGEMENT</span><span>TECHNICAL ANALYSIS</span>
      <span>ALGORITHMIC MODELS</span><span>JOURNALING SYSTEMS</span>
      <span>TRADE PSYCHOLOGY</span>
    </div>
  </div>

  <%- include('partials/stat-panel') %>

  <section class="work" id="services">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Capabilities</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Systems that navigate volatility.</h2>
    </div>
    
    <div class="work-grid">
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">FUTURES</span>
        <h3>Futures Execution</h3>
        <p>Strategic approaches and execution frameworks specifically tailored for NQ and ES futures markets.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">FOREX</span>
        <h3>Forex Markets</h3>
        <p>Analysis and disciplined trading strategies navigating major and minor currency pairs in global forex markets.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">RISK</span>
        <h3>Risk Management</h3>
        <p>Comprehensive risk-aware frameworks prioritizing capital preservation and structured position sizing.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.1s;">
        <span class="tag">TECH</span>
        <h3>Technical Analysis</h3>
        <p>Deep chart analysis, market structure mapping, and data-driven insights to identify high-probability setups.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.2s;">
        <span class="tag">ALGO</span>
        <h3>Algorithmic Models</h3>
        <p>Development of quantitative models and automated alerts integrating trading logic with software engineering.</p>
      </div>
      <div class="work-card reveal" style="transition-delay:0.3s;">
        <span class="tag">SYSTEM</span>
        <h3>Journaling Systems</h3>
        <p>Custom tracking and journaling systems to analyze trade data, review psychology, and iterate on edge.</p>
      </div>
    </div>
  </section>

  <% if (featuredProjects && featuredProjects.length > 0) { %>
  <section class="work" id="portfolio">
    <div class="reveal">
      <span class="eyebrow" style="margin-bottom:18px;">Execution</span>
      <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400;">Market Portfolio</h2>
      <p style="color:var(--ash); margin-top:10px;">Trading models, technical frameworks, and market analysis systems developed by ACED Trades.</p>
    </div>
    
    <div class="work-grid">
      <% featuredProjects.forEach((project, index) => { %>
        <div class="work-card reveal" style="transition-delay:<%= (index+1)*0.1 %>s;">
          <% (project.tags || []).slice(0, 3).forEach((tag) => { %>
            <span class="tag"><%= tag %></span>
          <% }) %>
          <h3><a href="/portfolio/<%= project.slug %>"><%= project.title %></a></h3>
          <p><%= project.description %></p>
        </div>
      <% }) %>
    </div>
    
    <div class="hero-cta reveal" style="margin-top:54px; justify-content:flex-start;">
      <a href="/portfolio?arm=trades" class="btn btn-ghost">View All Market Work</a>
    </div>
  </section>
  <% } %>

  <footer id="contact">
    <div class="aurora"><span class="a1"></span><span class="a2"></span></div>
    <div class="reveal">
      <p class="eyebrow" style="justify-content:center;margin-bottom:24px;">Engage</p>
      <h2>Let's build systems<br><em>with real impact.</em></h2>
      <p style="color:var(--ash); margin-top:20px; max-width:600px; margin-left:auto; margin-right:auto;">Discuss market strategy, risk frameworks, or trading software integrations.</p>
      <div class="foot-cta">
        <a href="mailto:avis@aceddivision.com" class="btn btn-primary">Start a Project</a>
      </div>
    </div>
    
    <div class="foot-links">
      <div class="foot-brand">
        <img src="/img/aceddivision-Logo-Icon-OnDark.png" alt="ACED">
        <span>© 2026 ACED Division LLC</span>
      </div>
      <div class="foot-social">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/admin/login">Admin</a>
      </div>
    </div>
  </footer>

  <script src="/js/aceddivision-v2.js"></script>
</body>
</html>
