<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/aceddivision-v2.css">
  <link rel="icon" href="/img/aceddivision-Logo-Icon-Gold.png" type="image/png">
  <style>
    .thumb-button { opacity: 0.6; transition: opacity 0.2s, border-color 0.2s; }
    .thumb-button:hover { opacity: 1; }
    .thumb-button.is-active { opacity: 1; border-color: var(--gold) !important; }
    
    .timeline-item { display:flex; gap:24px; margin-bottom:40px; }
    .timeline-marker { font-family:'IBM Plex Mono',monospace; font-size:24px; color:var(--gold); font-weight:500; }
    .timeline-body h3 { font-family:'Fraunces',serif; font-size:28px; font-weight:400; margin-bottom:12px; }
    .timeline-body p { color:var(--ash); line-height:1.6; }
    .timeline-image { margin-top:24px; border-radius:8px; border:1px solid var(--hair-2); }
    
    .obstacle-card { background:var(--ink); border:1px solid var(--hair-2); border-radius:12px; padding:32px; margin-bottom:24px; }
    .obstacle-card p { color:var(--ash); line-height:1.6; margin-top:8px; margin-bottom:24px; }
    .obstacle-card .label { font-family:'IBM Plex Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.1em; color:var(--ash-dim); }
    .obstacle-card .label.accent { color:var(--gold); }
  </style>
</head>
<body>

  <%- include('partials/navbar-v2') %>

  <section class="hero" id="heroSection" style="min-height: 50svh; padding-bottom: 40px; padding-top: 180px;">
    <div class="aurora"><span class="a1"></span><span class="a2"></span><span class="a3"></span></div>
    <div class="spotlight" id="spotlight"></div>
    <div class="grain"></div>
    <img class="watermark" src="/img/aceddivision-Logo-Icon-OnDark.png" alt="">
    
    <div class="hero-content reveal">
      <p class="eyebrow" style="justify-content:center;"><%= project.category.replace(/-/g, ' ').toUpperCase() %></p>
      <h1><%= project.title %></h1>
      <div style="margin-top: 20px; font-family:'IBM Plex Mono',monospace; font-size:12px; color:var(--ash);">
        <% if (project.client) { %><span style="margin-right:20px;"><strong style="color:var(--bone);">CLIENT:</strong> <%= project.client %></span><% } %>
        <% if (project.tags && project.tags.length) { %><span><strong style="color:var(--bone);">FOCUS:</strong> <%= project.tags.join(' · ') %></span><% } %>
      </div>
      <p class="sub" style="margin-top:20px;"><%= project.description %></p>
      <div class="hero-cta" style="margin-top:40px;">
        <a href="mailto:support@aceddivision.com" class="btn btn-primary">Start a Similar Project</a>
        <a href="/portfolio" class="btn btn-ghost">Browse More Work</a>
      </div>
    </div>
  </section>

  <section class="work reveal" style="max-width:1100px; margin:0 auto; padding: 40px 24px; padding-top:0;">
    <div style="border-radius:12px; overflow:hidden; border:1px solid var(--hair-2);">
      <img id="active-project-image" src="<%= project.images[0] %>" alt="<%= project.title %>" style="width:100%; display:block;">
    </div>
  </section>

  <% if (project.images && project.images.length > 1) { %>
    <section class="work reveal" style="max-width:1100px; margin:0 auto; padding: 0 24px 60px;">
      <div style="display:flex; gap:12px; overflow-x:auto; padding-bottom:12px;">
        <% project.images.forEach((image, index) => { %>
          <button class="thumb-button <%= index === 0 ? 'is-active' : '' %>" data-image="<%= image %>" style="flex-shrink:0; width:120px; height:80px; border-radius:6px; overflow:hidden; border:2px solid transparent; cursor:pointer; background:var(--ink); padding:0;">
            <img src="<%= image %>" alt="<%= project.title %> thumbnail <%= index + 1 %>" style="width:100%; height:100%; object-fit:cover;">
          </button>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (embedUrl || project.videoUrl) { %>
    <section class="work reveal" style="max-width:900px; margin:0 auto; padding: 40px 24px;">
      <div style="background:var(--ink); border:1px solid var(--hair-2); border-radius:12px; padding:40px;">
        <h2 style="font-family:'Fraunces',serif; font-size:32px; font-weight:400; margin-bottom:24px;">Media</h2>
        <% if (embedUrl) { %>
          <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:8px;">
            <iframe src="<%= embedUrl %>" title="<%= project.title %> video" allowfullscreen style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;"></iframe>
          </div>
        <% } else { %>
          <p style="color:var(--ash); margin-bottom:24px;">This project includes an external video or live experience.</p>
          <a href="<%= project.videoUrl %>" class="btn btn-primary" target="_blank" rel="noreferrer">Open Video or Live Link</a>
        <% } %>
      </div>
    </section>
  <% } %>

  <% if (project.milestones && project.milestones.length) { %>
    <section class="work reveal" style="max-width:900px; margin:0 auto; padding: 40px 24px;">
      <div style="margin-bottom:40px;">
        <p class="eyebrow">PROCESS</p>
        <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400; margin-top:12px;">How We Did It</h2>
      </div>
      <div>
        <% project.milestones.sort((left, right) => (left.order || 0) - (right.order || 0)).forEach((milestone, index) => { %>
          <article class="timeline-item">
            <div class="timeline-marker">0<%= index + 1 %></div>
            <div class="timeline-body">
              <h3><%= milestone.title %></h3>
              <p><%= milestone.description %></p>
              <% if (milestone.image) { %>
                <img src="<%= milestone.image %>" alt="<%= milestone.title %>" class="timeline-image">
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <% if (project.obstacles && project.obstacles.length) { %>
    <section class="work reveal" style="max-width:900px; margin:0 auto; padding: 40px 24px;">
      <div style="margin-bottom:40px;">
        <p class="eyebrow">OBSTACLES</p>
        <h2 style="font-family:'Fraunces',serif; font-size:42px; font-weight:400; margin-top:12px;">Challenges and Solutions</h2>
      </div>
      <div>
        <% project.obstacles.forEach((obstacle) => { %>
          <article class="obstacle-card">
            <div>
              <span class="label">Challenge</span>
              <p><%= obstacle.challenge %></p>
            </div>
            <div>
              <span class="label accent">Solution</span>
              <p><%= obstacle.solution %></p>
            </div>
            <% if (obstacle.image) { %>
              <img src="<%= obstacle.image %>" alt="Obstacle evidence" style="margin-top:16px; border-radius:8px; border:1px solid var(--hair-2);">
            <% } %>
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>

  <footer id="contact" style="margin-top:60px;">
    <div class="aurora"><span class="a1"></span><span class="a2"></span></div>
    <div class="reveal">
      <p class="eyebrow" style="justify-content:center;margin-bottom:24px;">Engage</p>
      <h2>Want a system<br><em>like this?</em></h2>
      <p style="color:var(--ash); margin-top:20px; max-width:600px; margin-left:auto; margin-right:auto;">Tell us what you are building, what is slowing you down, and what success should look like.</p>
      <div class="foot-cta">
        <a href="mailto:support@aceddivision.com" class="btn btn-primary">support@aceddivision.com</a>
      </div>
    </div>
    
    <div class="foot-links">
      <div class="foot-brand">
        <img src="/img/aceddivision-Logo-Icon-OnDark.png" alt="ACED">
        <span>© 2026 ACED Division LLC</span>
      </div>
      <div class="foot-social">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/admin/login">Admin</a>
      </div>
    </div>
  </footer>

  <script src="/js/aceddivision-v2.js"></script>
  <script>
    document.querySelectorAll('.thumb-button').forEach((button) => {
      button.addEventListener('click', () => {
        document.getElementById('active-project-image').src = button.dataset.image;
        document.querySelectorAll('.thumb-button').forEach((item) => item.classList.remove('is-active'));
        button.classList.add('is-active');
      });
    });
  </script>
</body>
</html>
