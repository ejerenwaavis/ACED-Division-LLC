<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/img/Logo-Icon.png" type="image/png">
</head>
<body>
  <div class="ambient-gradient"></div>
  <div class="ambient-diagonal"></div>

  <div class="login-shell">
    <div class="login-card">
      <img src="/img/Logo-Icon.png" alt="ACED Division" class="logo-icon">
      <h1>Admin Access</h1>
      <p>Enter your admin password to manage the portfolio.</p>

      <% if (error) { %>
        <div class="login-error"><%= error %></div>
      <% } %>

      <form action="/admin/login" method="post">
        <input
          type="password"
          name="password"
          placeholder="Admin password"
          autocomplete="current-password"
          autofocus
        >
        <button type="submit" class="btn btn-accent" style="width:100%; justify-content:center;">
          Sign In
        </button>
      </form>

      <p style="margin-top:1.4rem; font-size:0.84rem;">
        <a href="/">← Back to site</a>
      </p>
    </div>
  </div>
</body>
</html>
