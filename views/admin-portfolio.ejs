<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" href="/img/Logo-Icon.png" type="image/png">
</head>
<body class="admin-body">
  <div class="ambient-gradient"></div>
  <div class="ambient-grid"></div>

  <header class="admin-page-header">
    <nav>
      <div class="logo"><img src="/img/Logo-Icon.png" alt="ACED" class="logo-icon"> <span>ACED Admin</span></div>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/portfolio">Portfolio</a></li>
        <li><a href="/admin/users">Users</a></li>
        <li><a href="/admin/account">Account</a></li>
        <li><a href="/admin/logout">Logout</a></li>
      </ul>
    </nav>
  </header>

  <main class="admin-panel">
    <header class="admin-panel-header">
      <div>
        <h1>Portfolio Admin Console</h1>
        <p>Clean, modern workspace to oversee projects, user actions, and quality control.</p>
      </div>
      <div class="admin-panel-actions">
        <a href="/admin/logout" class="btn btn-secondary">Sign Out</a>
        <a href="/admin/portfolio/new" class="btn btn-accent">Add New Project</a>
      </div>
    </header>

    <section class="admin-cards">
      <% if (!projects.length) { %>
        <div class="empty-state">
          <h2>No portfolio projects yet</h2>
          <p>Start by creating a new project with the button above.</p>
        </div>
      <% } %>

      <% projects.forEach((project) => { %>
        <article class="project-card">
          <div class="project-card-image" style="background-image:url('<%= project.images[0] %>');"></div>
          <div class="project-card-body">
            <div class="project-tags">
              <span class="chip"><%= project.category.replace(/-/g, ' ') %></span>
              <% if (project.arm) { %>
                <span class="chip"><%= project.arm %></span>
              <% } %>
            </div>
            <h3><%= project.title %></h3>
            <p class="muted"><%= project.client || 'ACED Division' %></p>
            <div class="project-card-actions">
              <a href="/portfolio/<%= project.slug %>" class="btn btn-outline">Preview</a>
              <a href="/admin/portfolio/<%= project.slug %>/edit" class="btn btn-primary">Edit</a>
              <form action="/admin/portfolio/<%= project.slug %>/delete" method="post" onsubmit="return confirm('Delete this project?');">
                <button type="submit" class="btn btn-danger">Delete</button>
              </form>
            </div>
          </div>
        </article>
      <% }) %>
    </section>

    <section class="admin-grid-footer">
      <a href="/admin/users" class="btn btn-outline">Manage Users</a>
      <a href="/admin/account" class="btn btn-outline">Account Settings</a>
    </section>
  </main>
</body>
</html>
